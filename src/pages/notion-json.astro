---
export const prerender = false;

import { Client } from "@notionhq/client";
import Layout from "../layouts/Layout.astro";
import "../styles/post.css";
import Accordion from "../components/Accordion/index.astro";
import AccordionItem from "../components/Accordion/AccordionItem.astro";

const notion = new Client({
  auth: import.meta.env.NOTION_TOKEN,
});

const DATA_SOURCE_ID = import.meta.env.NOTION_DATA_SOURCE_ID;

function richTextToPlainText(richText = []) {
  return richText.map((item: any) => item.plain_text ?? "").join("");
}

function getTitle(prop: any) {
  if (!prop || prop.type !== "title") return "";
  return richTextToPlainText(prop.title);
}

function getMultiSelect(prop: any) {
  if (!prop || prop.type !== "multi_select") return [];
  return (prop.multi_select ?? []).map((item: any) => item.name);
}

function getUniqueId(prop: any) {
  if (!prop || prop.type !== "unique_id") return "";
  const prefix = prop.unique_id?.prefix ?? "";
  const number = prop.unique_id?.number ?? "";
  return `${prefix}${number}`;
}

function getCreatedBy(prop: any) {
  if (!prop || prop.type !== "created_by") return "";
  return prop.created_by?.name ?? "";
}

function getLastEditedBy(prop: any) {
  if (!prop || prop.type !== "last_edited_by") return "";
  return prop.last_edited_by?.name ?? "";
}

function getCreatedTime(prop: any) {
  if (!prop || prop.type !== "created_time") return "";
  return prop.created_time ?? "";
}

function getLastEditedTime(prop: any) {
  if (!prop || prop.type !== "last_edited_time") return "";
  return prop.last_edited_time ?? "";
}

function renderRichText(richText = []) {
  return richText.map((item: any) => item.plain_text ?? "").join("");
}

function renderBlockText(block: any) {
  const type = block.type;
  const data = block[type];
  if (!data) return "";
  if ("rich_text" in data) return renderRichText(data.rich_text);
  return "";
}

async function getPostsWithContent() {
  const response = await notion.request({
    path: `data_sources/${DATA_SOURCE_ID}/query`,
    method: "post",
    body: {
      page_size: 10,
    },
  });

  const results = response.results ?? [];

  const posts = await Promise.all(
    results.map(async (page: any) => {
      const properties = page.properties ?? {};

      let blocks = [];
      let cursor = undefined;

      while (true) {
        const blocksResponse = await notion.blocks.children.list({
          block_id: page.id,
          start_cursor: cursor,
          page_size: 100,
        });

        blocks.push(...(blocksResponse.results ?? []));

        if (!blocksResponse.has_more) break;
        cursor = blocksResponse.next_cursor ?? undefined;
      }

      return {
        id: page.id,
        nome: getTitle(properties["Nome"]),
        tags: getMultiSelect(properties["Tags"]),
        codigo: getUniqueId(properties["ID"]),
        autor: getCreatedBy(properties["Author"]),
        dataPublicacao: getCreatedTime(properties["Data de publicação "]),
        ultimaEdicao: getLastEditedTime(properties["Última edição"]),
        ultimaEdicaoPor: getLastEditedBy(properties["Última edição por"]),
        propriedades: properties,
        blocks,
      };
    }),
  );

  return posts;
}

let posts = [];
let error = null;

try {
  posts = await getPostsWithContent();
} catch (err) {
  error = err instanceof Error ? err.message : String(err);
}
---

<Layout>
  <h1>Teste de posts do Notion</h1>

  {
    error ? (
      <pre>{error}</pre>
    ) : (
      posts.map((post: any) => (
        <section class="space-y-5">
          <h2>{post.nome || "Sem título"}</h2>
          <Accordion>
            <AccordionItem title="JSON bruto das propriedades">
              <pre>{JSON.stringify(post.propriedades, null, 2)}</pre>
            </AccordionItem>
            <AccordionItem title="JSON bruto dos blocos">
              <pre>{JSON.stringify(post.blocks, null, 2)}</pre>
            </AccordionItem>
          </Accordion>
        </section>
      ))
    )
  }
</Layout>
