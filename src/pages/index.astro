---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import Box from "../components/Box/index.astro";
import WhiteHead from "../components/Box/WhiteHead.astro";
import Slide from "../components/Slide.astro";
import SlideNumber from "../components/SlideNumber.astro";
import Layout from "../layouts/Layout.astro";
import NumberLine from "../components/Box/NumberLine.astro";
import Naked from "../components/Box/Naked.astro";

interface Conteudo {
  title?: string;
  content: string;
  className?: string;
  type?: AstroComponentFactory;
}

const caixasSlide1: Conteudo[] = [
  {
    title: "O Problema",
    content: "Hoje, sites são pesados e carregam JavaScript desnecessário.",
  },
  {
    title: "A Consequência",
    content:
      "Sites lentos afastam clientes e são punidos pelo Google (SEO ruim).",
  },
  {
    title: "A Solução",
    content:
      "Astro, o framework projetado para entregar velocidade máxima sem esforço.",
  },
  {
    content:
      "O <strong>Astro</strong> é um framework focado em performance que prioriza o envio de <strong>HTML puro</strong> para o navegador, eliminando JavaScript desnecessário para garantir carregamento instantâneo e SEO superior. Através da <strong>Arquitetura de Ilhas</strong>, ele permite integrar componentes de React, Vue ou Svelte apenas onde a interatividade é essencial, sendo a solução mais ágil e versátil para construir Landing Pages e sites institucionais de alta conversão.",
    className: "col-span-1 md:col-span-3",
    type: WhiteHead,
  },
];

const caixasSlide3: Conteudo[] = [
  {
    title: "Conteúdo Visível",
    content:
      "Como o Astro gera páginas estáticas, os robôs de busca (Google) leem todo o seu conteúdo instantaneamente.",
  },
  {
    title: "Core Web Vitals",
    content:
      "O Astro é otimizado nativamente para passar em todos os testes de qualidade do Google.",
  },
  {
    title: "URLs Canônicas e Metadados",
    content:
      "Gerenciamento simplificado para garantir que sua marca apareça no topo das buscas.",
  },
];

const caixasSlide4: Conteudo[] = [
  {
    title: "Liberdade Total",
    content:
      "Você não precisa escolher entre React, Vue ou Svelte. O Astro permite usar todos eles no mesmo projeto.",
  },
  {
    title: "Design com Tailwind",
    content:
      "Integração nativa com Tailwind CSS para criar visuais modernos e responsivos em tempo recorde.",
  },
  {
    title: "Sem Barreiras",
    content: "Se sua equipe já conhece uma ferramenta, ela já sabe usar Astro.",
  },
];

const caixasSlide5: Conteudo[] = [
  {
    title: "Simplicidade de Pastas",
    content:
      "Criar uma nova página é tão fácil quanto criar um arquivo. Criou sobre.astro? A página seusite.com/sobre já existe.",
  },
  {
    title: "Rotas Dinâmicas",
    content:
      "Ideal para Blogs ou Catálogos. Com um único modelo, você gera centenas de páginas (ex: /blog/post-1, /blog/post-2).",
  },
  {
    title: "Organização Intuitiva",
    content: "Menos código de configuração, mais foco no conteúdo.",
  },
];

const caixasSlide6: Conteudo[] = [
  {
    title: "O que é?",
    content:
      "Imagine um oceano de conteúdo estático (rápido) com pequenas ilhas de interatividade.",
  },
  {
    title: "Como funciona",
    content:
      "Apenas os componentes que precisam de ação (como um formulário ou um carrossel) carregam código. O resto do site permanece leve como uma pena.",
  },
  {
    title: "Vantagem",
    content:
      "O usuário interage com o que importa, enquanto o site carrega instantaneamente ao fundo.",
    className: "md:row-span-2",
  },
];
---

<Layout>
  <!-- <SlideNav qtd="6" /> -->
  <img
    width="800"
    src="\astro-logo-light-gradient.svg"
    alt="astro"
    class="m-auto"
  />

  <Slide>
    <SlideNumber>Slide 1</SlideNumber>
    <h2>O Desafio</h2>
    <ul class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        caixasSlide1.map((caixa) => (
          <Box title={caixa.title} class={caixa.className} type={caixa.type}>
            <p set:html={caixa.content} />
          </Box>
        ))
      }
    </ul>
  </Slide>

  <Slide>
    <SlideNumber>Slide 2</SlideNumber>
    <h2>Por que o Astro é tão Ágil?</h2>

    <ul class="space-y-5 text-2xl list-disc pl-10">
      <li>
        <strong>Filosofia "Zero JavaScript":</strong> O Astro remove todo o código
        pesado e envia apenas HTML puro para o navegador.
      </li>
      <li>
        <strong>Build Estático:</strong> O site é "pré-fabricado" no momento da criação.
        Quando o cliente clica, o site já está pronto, sem precisar "pensar".
      </li>
      <li>
        <strong>Performance Incomparável:</strong> Ideal para Landing Pages (LPs)
        e Sites Institucionais que precisam converter visitantes em segundos.
      </li>
    </ul>
  </Slide>

  <Slide>
    <SlideNumber>Slide 3</SlideNumber>
    <h2>SEO: O Melhor Amigo do Google</h2>
    <ul class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {
        caixasSlide3.map((caixa) => (
          <Box title={caixa.title} class={caixa.className} type={WhiteHead}>
            <p set:html={caixa.content} />
          </Box>
        ))
      }
    </ul>
  </Slide>

  <Slide>
    <SlideNumber>Slide 4</SlideNumber>

    <h2>Versatilidade: Use o Melhor de Cada Mundo</h2>

    <ul class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {
        caixasSlide4.map((caixa) => (
          <Box title={caixa.title} class={caixa.className} type={Naked}>
            <p set:html={caixa.content} />
          </Box>
        ))
      }
    </ul>
  </Slide>

  <Slide
    src="https://cdn.gamma.app/fzd9z4zd3y750c3/generated-images/obvHNvgKKhPcudzueCY6r.jpg"
    imgSide="right"
    class=""
  >
    <SlideNumber>Slide 5</SlideNumber>
    <h2>Roteamento Inteligente</h2>
    <h5 id="5">(Baseado em Arquivos)</h5>
    <ul class="grid grid-cols-1 gap-5">
      {
        caixasSlide5.map((caixa, index) => (
          <Box
            title={caixa.title}
            class={caixa.className}
            type={NumberLine}
            index={index++}
          >
            <p set:html={caixa.content} />
          </Box>
        ))
      }
    </ul>
  </Slide>

  <Slide>
    <SlideNumber>Slide 6</SlideNumber>
    <h2>O Segredo: Arquitetura de Ilhas (Islands)</h2>
    <ul
      class="grid grid-cols-1 grid-rows-1 md:grid-cols-2 md:grid-rows-2 md:grid-flow-col gap-5 justify-center items-center"
    >
      {
        caixasSlide6.map((caixa) => (
          <Box title={caixa.title} class={caixa.className} type={Naked}>
            <p set:html={caixa.content} />
          </Box>
        ))
      }
    </ul>
  </Slide>
</Layout>
