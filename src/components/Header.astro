---
import HeaderLink from "./HeaderLink.astro";
import logoP from "../assets/logo-p.svg";
import { Image } from "astro:assets";
---

<header class="sticky top-0 w-full p-6 z-999">
  <nav
    class="max-w-200 mx-auto p-4 px-6 bg-[#00000080] backdrop-blur-xl
  rounded-full flex items-center justify-between"
  >
    <a href="/">
      <Image width="20" src={logoP} alt="Logo" />
    </a>
    <div class="space-x-6">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/blog-notion">Notion</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
  </nav>
</header>
