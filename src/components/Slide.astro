---
interface Props {
  src?: string;
  imgSide?: "left" | "right";
}

const { src, imgSide = "right" } = Astro.props;

const isLeft = imgSide === "left" && true;
---

<section
  class="relative overflow-hidden w-full bg-[#20132CAA] rounded-2xl flex flex-row text-white border-2 border-[#DE386B]"
>
  <div
    class:list={[
      "p-6 md:py-10 md:px-12 flex flex-col gap-6 max-w-full",
      { "w-1/2": src },
      isLeft ? "ml-auto" : "mr-auto",
    ]}
  >
    <slot />
    {
      src && (
        <div
          class:list={[
            "absolute top-0 bottom-0 w-1/2",
            isLeft ? "left-0" : "right-0",
          ]}
        >
          <img
            width="100"
            {src}
            alt=""
            class="object-cover object-center h-full w-full"
          />
          <div
            class:list={[
              "absolute inset-0 from-[#181021] from-0% to-transparent to-100%",
              isLeft ? "bg-linear-to-l" : "bg-linear-to-r",
            ]}
          />
        </div>
      )
    }
  </div>
</section>
