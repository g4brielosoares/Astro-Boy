---
import "@/styles/global.css";

import BaseHead from "@/components/primitives/content/BaseHead.astro";
import Footer from "@/components/patterns/Footer.astro";
import Header from "@/components/patterns/Header.astro";
import type { Props } from "@/components/primitives/content/BaseHead.astro";

const { title, description, imageURL } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead {title} {description} {imageURL} />
  </head>
  <body class="bg-zinc-950 text-white font-atkinson leading-normal">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
