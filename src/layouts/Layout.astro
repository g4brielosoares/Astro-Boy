---
import "../styles/global.css";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

import type { HeadProps } from "../navigation";

type Props = HeadProps;

const { title, description, imageURL, canonicalURL } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
  <head>
    <BaseHead {title} {description} {imageURL} />
  </head>
  <body class="bg-zinc-950 text-white font-atkinson leading-normal">
    <Header />
    <main
      class="w-5/6 max-w-300 mx-auto space-y-6 md:space-y-10 py-16 md:py-24"
    >
      <slot />
    </main>
    <Footer />
  </body>
</html>
